{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "system-monitor-app",
  "version": "0.1.0",
  "identifier": "com.system-monitor-app.app",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "System Monitor",
        "width": 920,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": true,
        "alwaysOnTop": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "System Monitor"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/README.md": "../README.md",
          "/usr/share/assets": "../assets/"
        }
      }
    }
  }
}
