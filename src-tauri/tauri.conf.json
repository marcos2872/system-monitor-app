{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "system-monitor-app",
  "version": "0.1.0",
  "identifier": "com.system-monitor-app.app",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "System Monitor",
        "fullscreen": false,
        "height": 200,
        "width": 430,
        "alwaysOnTop": true,
        "closable": false,
        "decorations": false,
        "dragDropEnabled": false,
        "focus": false,
        "hiddenTitle": true,
        "label": "main",
        "maximizable": false,
        "minimizable": false,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "transparent": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/README.md": "../README.md"
        }
      }
    }
  }
}
