{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "system-monitor-app",
  "version": "0.1.0",
  "identifier": "com.system-monitor-app.app",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "System Monitor",
        "width": 320,
        "height": 240,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "System Monitor",
      "menuOnLeftClick": false,
      "id": "main"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
